{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "singleQuote": true,
  "trailingComma": "es5",
  "semi": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": {},
  "ignorePatterns": [
    "node_modules/**",
    ".wrangler/**",
    "dist/**",
    "coverage/**",
    ".serena/**",
    ".claude/**"
  ]
}
