{
  "name": "qiita-x-bot",
  "version": "1.0.0",
  "description": "Automatically post Qiita articles to X (Twitter) with AI evaluation",
  "keywords": [
    "claude",
    "cloudflare-workers",
    "hono",
    "qiita",
    "twitter",
    "x"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "oxlint --fix src/ && oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "ci": "bun run typecheck && bun run lint && bun run format:check && bun run test:coverage",
    "tools:fetch-members": "bun run tools/fetch-org-members.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "hono": "^4.12.8",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
